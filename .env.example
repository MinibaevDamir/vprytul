# Аналітика (ТЗ, розділ 3). Без цих значень скрипти не підключаються.
NUXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NUXT_PUBLIC_FB_PIXEL_ID=000000000000000

# Прямі посилання на маркети (з'являться після рев'ю застосунку).
